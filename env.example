# ─────────────────────────────────────────────────────────────────────────────
# HOMEXO — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Django Core
SECRET_KEY=your-very-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=homexo.in,www.homexo.in

# Database — PostgreSQL (required in production)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=homexo_db
DB_USER=homexo
DB_PASSWORD=change-this-strong-password
DB_HOST=db
DB_PORT=5432

# ─── Docker Image (used by docker-compose.prod.yml) ──────────────────────────
IMAGE_NAME=homexo/homexo-production
IMAGE_TAG=latest

# ─── Email — Zoho Mail ────────────────────────────────────────────────────────
# SMTP host: smtp.zoho.in (India) | Port 587 + TLS  OR  Port 465 + SSL
# App Password: Zoho Mail → Settings → Security → App Passwords → Generate
# IMPORTANT: DEFAULT_FROM_EMAIL must exactly match EMAIL_HOST_USER in Zoho —
# otherwise Zoho will reject the send with "Sender address mismatch".
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.zoho.in
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
# If you prefer SSL on port 465, flip the two values:
#   EMAIL_PORT=465  EMAIL_USE_TLS=False  EMAIL_USE_SSL=True
EMAIL_HOST_USER=noreply@homexo.in
EMAIL_HOST_PASSWORD=your-zoho-app-password
DEFAULT_FROM_EMAIL=noreply@homexo.in       # must match EMAIL_HOST_USER in Zoho
ENQUIRY_NOTIFICATION_EMAIL=hello@homexo.in  # team inbox — receives enquiry alerts

# Media / Storage (leave blank for local storage in development)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=ap-south-1

# CORS (comma-separated list of allowed origins in production)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Social OAuth ─────────────────────────────────────────────────────────────
# Google OAuth2: https://console.cloud.google.com/apis/credentials
# Create an "OAuth 2.0 Client ID" (Web application).
# Authorised redirect URI: http://localhost:8000/social-auth/complete/google-oauth2/
GOOGLE_OAUTH2_KEY=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH2_SECRET=your-google-client-secret

# Facebook App: https://developers.facebook.com/apps
# Add "Facebook Login" product. Authorised redirect URI:
# https://homexo.in/social-auth/complete/facebook/
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ─── Twilio (Phone OTP) ───────────────────────────────────────────────────────
# Sign up at https://www.twilio.com — leave blank to print OTPs to console
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+12015551234

# ─── AI / RAG — Urvashi Chatbot ───────────────────────────────────────────────
# Chatbot disabled on 1 GB and 2 GB plans (needs ~1.2 GB RAM for sentence-transformers).
# Enable only when upgrading to 4 GB Droplet ($32/mo).
# LLM_API_KEY=your-anthropic-api-key
# LLM_MODEL=claude-haiku-4-5-20251001
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# EMBEDDING_DIM=384
# TOP_K=5
# SIMILARITY_THRESHOLD=0.35

# ─── Plan Tuning — Gunicorn & PostgreSQL ──────────────────────────────────────
# Change these values when switching DigitalOcean plans.
# No image rebuild needed — just update .env and run:
#   docker compose -f docker-compose.prod.yml up -d
#
#                     $8/mo (1 GB)   $16/mo (2 GB)   $32/mo (4 GB)
#                     ─────────────  ─────────────   ─────────────
GUNICORN_WORKERS=1  #      1              2                3
GUNICORN_THREADS=2  #      2              4                4
GUNICORN_MAX_REQUESTS=500  # 500          1000             1000
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

# PostgreSQL memory (tuned to stay under budget per plan)
PG_SHARED_BUFFERS=32MB    # 32MB        64MB            128MB
PG_EFFECTIVE_CACHE=96MB   # 96MB        256MB           512MB
PG_WORK_MEM=2MB           # 2MB         4MB             8MB
PG_MAINT_MEM=16MB         # 16MB        32MB            64MB
PG_MAX_CONN=20            # 20          50              100

# Docker container memory limits
DB_MEM_LIMIT=128m         # 128m        256m            512m
DB_MEMSWAP_LIMIT=256m     # 256m        512m            1g
WEB_MEM_LIMIT=256m        # 256m        512m            1g
WEB_MEMSWAP_LIMIT=512m    # 512m        1g              2g
