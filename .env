# ─────────────────────────────────────────────────────────────────────────────
# HOMEXO — Local Development Environment Variables
# This file is for LOCAL DEV only (DEBUG=True, localhost DB).
# On the DROPLET, create /opt/homexo/.env from env.example instead.
# Never commit this file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Django Core
SECRET_KEY=your-very-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — PostgreSQL (local dev)
# Make sure your local Postgres has this DB and user created:
#   createdb homexo_db && createuser homexo_user
DB_ENGINE=django.db.backends.postgresql
DB_NAME=homexo_db
DB_USER=homexo_user
DB_PASSWORD=homexo_secret
DB_HOST=localhost
DB_PORT=5432
# Fallback SQLite (uncomment to use during local dev without Postgres):
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3

# ─── Docker Image (used by docker-compose.prod.yml) ──────────────────────────
IMAGE_NAME=your-dockerhub-username/homexo
IMAGE_TAG=latest

# Email (console backend in dev — emails print to terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@homexo.in
ENQUIRY_NOTIFICATION_EMAIL=enquiries@homexo.in

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Social OAuth ─────────────────────────────────────────────────────────────
GOOGLE_OAUTH2_KEY=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH2_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ─── Twilio (Phone OTP) ───────────────────────────────────────────────────────
# Leave blank in dev — OTPs print to the terminal console instead
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── AI / RAG — Urvashi Chatbot ───────────────────────────────────────────────
# Chatbot disabled in INSTALLED_APPS until upgrading to 4 GB Droplet.
LLM_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
TOP_K=5
SIMILARITY_THRESHOLD=0.35

# ─── Plan Tuning — Gunicorn & PostgreSQL ──────────────────────────────────────
# These defaults match the $8/mo 1 GB plan.
# On the DROPLET .env, change these when upgrading plans — no rebuild needed.
#
#                     $8/mo (1 GB)   $16/mo (2 GB)   $32/mo (4 GB)
#                     ─────────────  ─────────────   ─────────────
GUNICORN_WORKERS=1  #      1              2                3
GUNICORN_THREADS=2  #      2              4                4
GUNICORN_MAX_REQUESTS=500  # 500          1000             1000
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

# PostgreSQL memory (tuned per plan)
PG_SHARED_BUFFERS=32MB    # 32MB         64MB            128MB
PG_EFFECTIVE_CACHE=96MB   # 96MB         256MB           512MB
PG_WORK_MEM=2MB           # 2MB          4MB             8MB
PG_MAINT_MEM=16MB         # 16MB         32MB            64MB
PG_MAX_CONN=20            # 20           50              100

# Docker container memory limits
DB_MEM_LIMIT=128m         # 128m         256m            512m
DB_MEMSWAP_LIMIT=256m     # 256m         512m            1g
WEB_MEM_LIMIT=256m        # 256m         512m            1g
WEB_MEMSWAP_LIMIT=512m    # 512m         1g              2g